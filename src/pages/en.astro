---
import "../styles/global.css";
import "../styles/resume.css";
import "../styles/inverted-card.css";
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar";
import Hero from "../sections/Hero.astro";
import Service from "../sections/Service.astro";
import Skill from "../sections/Skill.astro";
import Certifications from "../sections/Certifications.astro";
import Proyects from "../sections/Proyects.astro";
import Education from "../sections/Education.astro";
import Footer from "../sections/Footer.astro";

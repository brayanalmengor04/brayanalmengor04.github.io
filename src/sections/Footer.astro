---
import {
  FaArrowRight,
  FaFacebook,
  FaInstagram,
  FaLinkedin,
  FaTwitter,
  FaYoutube,
} from "react-icons/fa";

// ✨ Magia dinámica: el año se actualiza automáticamente
const currentYear = new Date().getFullYear();

import { useTranslations } from "../i18n/utils";
const { lang = "es" } = Astro.props;
const t = useTranslations(lang);
---

<footer
  class="bg-secondary text-theme-primary py-8 sm:py-12 px-4 sm:px-6 md:px-12 lg:px-24"
>
  <div class="container mx-auto">
    <!-- Sección superior con título y botón -->
    <div
      class="flex flex-col md:flex-row justify-between items-center mb-8 sm:mb-12 text-center md:text-left"
    >
      <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold">
        {t("footer.connect")}
      </h2>
      <button
        class="bg-theme-magenta-blue hover:bg-primary text-white rounded-md px-4 sm:px-6 py-2 mt-4 md:mt-0 cursor-pointer"
      >
        {t("footer.btn")}
      </button>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 sm:gap-8">
      <div class="space-y-4 sm:space-y-6 text-center md:text-left">
        <div
          class="flex justify-center md:justify-start items-center space-x-2"
        >
          <div
            class="rounded-full w-10 h-10 flex items-center justify-center font-bold text-white transition-all duration-300 hover:scale-110"
            style="background: var(--accent-primary); box-shadow: var(--shadow-glow);"
          >
            BA
          </div>
        </div>
        <p class="text-theme-secondary text-sm max-w-xs mx-auto md:mx-0">
          {t("footer.desc")}
        </p>
        <div class="flex justify-center md:justify-start space-x-3">
          <a
            href="#"
            class="text-theme-muted hover:text-theme-primary transition-colors"
          >
            <FaFacebook size={18} />
          </a>
          <a
            href="https://www.instagram.com/aabj_cx"
            class="text-theme-muted hover:text-theme-primary transition-colors"
          >
            <FaInstagram size={18} />
          </a>
          <a
            href="https://www.linkedin.com/in/brayan-antonio"
            class="text-theme-muted hover:text-theme-primary transition-colors"
          >
            <FaLinkedin size={18} />
          </a>
          <a
            href="#"
            class="text-theme-muted hover:text-theme-primary transition-colors"
          >
            <FaTwitter size={18} />
          </a>
          <a
            href="#"
            class="text-theme-muted hover:text-theme-primary transition-colors"
          >
            <FaYoutube size={18} />
          </a>
        </div>
      </div>
      <!-- Navegación -->
      <div class="text-center md:text-left">
        <h3 class="font-medium mb-4">{t("footer.nav")}</h3>
        <ul class="space-y-2">
          <li>
            <a
              href="#home"
              class="text-theme-muted hover:text-theme-primary transition-colors text-sm"
            >
              {t("nav.home")}
            </a>
          </li>
          <li>
            <a
              href="#resume"
              class="text-theme-muted hover:text-theme-primary transition-colors text-sm"
            >
              {t("nav.resume")}
            </a>
          </li>
          <li>
            <a
              href="#service"
              class="text-theme-muted hover:text-theme-primary transition-colors text-sm"
            >
              {t("nav.service")}
            </a>
          </li>
          <li>
            <a
              href="#resume"
              class="text-theme-muted hover:text-theme-primary transition-colors text-sm"
            >
              {t("nav.resume")}
            </a>
          </li>
          <li>
            <a
              href="#portfolio"
              class="text-theme-muted hover:text-theme-primary transition-colors text-sm"
            >
              {t("nav.portfolio")}
            </a>
          </li>
        </ul>
      </div>
      <div class="text-center md:text-left">
        <h3 class="font-medium mb-4">{t("footer.contact")}</h3>
        <ul class="space-y-2">
          <li class="text-theme-muted text-sm">brayanalmengor300@gmail.com</li>
          <li class="text-theme-muted text-sm">brayanalmengor.netlify.app</li>
        </ul>
      </div>
      <div class="text-center md:text-left">
        <h3 class="font-medium mb-4">{t("footer.latest")}</h3>
        <div class="flex justify-center md:justify-start relative group">
          <input
            type="email"
            placeholder={t("footer.email.placeholder")}
            class="px-4 py-2 rounded-l-md w-full text-sm focus:outline-none transition-all duration-300"
            style="background: var(--bg-tertiary); color: var(--text-primary); border: 1px solid var(--border-secondary);"
          />
          <button
            class="rounded-r-md px-4 py-2 flex items-center justify-center transition-all duration-300 hover:shadow-lg"
            style="background: var(--accent-primary); color: white; border: 1px solid var(--accent-primary);"
            onmouseover="this.style.background='var(--gradient-primary)'; this.style.transform='scale(1.05)';"
            onmouseout="this.style.background='var(--accent-primary)'; this.style.transform='scale(1)';"
          >
            <FaArrowRight size={18} />
          </button>
        </div>
      </div>
    </div>

    <div
      class="border-t border-gray-800 mt-8 sm:mt-12 pt-4 sm:pt-6 flex flex-col md:flex-row justify-between items-center text-center md:text-left"
    >
      <!-- 🎉 ¡Año dinámico que se actualiza solo! -->
      <p class="text-theme-muted text-sm">
        {t("footer.copyright").replace("{year}", currentYear)}
      </p>
      <div
        class="flex flex-col md:flex-row space-y-2 md:space-y-0 md:space-x-4 mt-4 md:mt-0"
      >
        <a
          href="#"
          class="text-theme-muted hover:text-theme-primary transition-colors text-sm"
        >
          {t("footer.terms")}
        </a>
        <span class="text-theme-muted">|</span>
        <a
          href="#"
          class="text-theme-muted hover:text-theme-primary transition-colors text-sm"
        >
          {t("footer.privacy")}
        </a>
      </div>
    </div>
  </div>
</footer>

---
import {
  FaArrowRight,
  FaFacebook,
  FaInstagram,
  FaLinkedin,
  FaTwitter,
  FaYoutube,
} from "react-icons/fa";

// ✨ Magia dinámica: el año se actualiza automáticamente
const currentYear = new Date().getFullYear();

import { useTranslations } from "../i18n/utils";
const { lang = "es" } = Astro.props;
const t = useTranslations(lang);
---

<footer
  class="bg-secondary text-theme-primary py-8 sm:py-12 px-4 sm:px-6 md:px-12 lg:px-24"
>
  <div class="container mx-auto">
    <!-- Sección superior con título y botón -->
    <div
      class="flex flex-col md:flex-row justify-between items-center mb-8 sm:mb-12 text-center md:text-left"
    >
      <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold">
        {t("footer.connect")}
      </h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 sm:gap-8">
      <div class="space-y-4 sm:space-y-6 text-center md:text-left">
        <div
          class="flex justify-center md:justify-start items-center space-x-2"
        >
          <div
            class="rounded-full w-10 h-10 flex items-center justify-center font-bold text-white transition-all duration-300 hover:scale-110"
            style="background: var(--accent-primary); box-shadow: var(--shadow-glow);"
          >
            BA
          </div>
        </div>
        <p class="text-theme-secondary text-sm max-w-xs mx-auto md:mx-0">
          {t("footer.desc")}
        </p>
        <div class="flex justify-center md:justify-start space-x-3">
          <a
            href="#"
            class="text-theme-muted hover:text-theme-primary transition-colors"
          >
            <FaFacebook size={18} />
          </a>
          <a
            href="https://www.instagram.com/aabj_cx"
            class="text-theme-muted hover:text-theme-primary transition-colors"
          >
            <FaInstagram size={18} />
          </a>
          <a
            href="https://www.linkedin.com/in/brayan-antonio"
            class="text-theme-muted hover:text-theme-primary transition-colors"
          >
            <FaLinkedin size={18} />
          </a>
          <a
            href="#"
            class="text-theme-muted hover:text-theme-primary transition-colors"
          >
            <FaTwitter size={18} />
          </a>
          <a
            href="#"
            class="text-theme-muted hover:text-theme-primary transition-colors"
          >
            <FaYoutube size={18} />
          </a>
        </div>
      </div>
      <!-- Navegación -->
      <div class="text-center md:text-left">
        <h3 class="font-medium mb-4">{t("footer.nav")}</h3>
        <ul class="space-y-2">
          <li>
            <a
              href="#home"
              class="text-theme-muted hover:text-theme-primary transition-colors text-sm"
            >
              {t("nav.home")}
            </a>
          </li>
          <li>
            <a
              href="#skill"
              class="text-theme-muted hover:text-theme-primary transition-colors text-sm"
            >
              {t("nav.skill")}
            </a>
          </li>
          <li>
            <a
              href="#experience-services"
              class="text-theme-muted hover:text-theme-primary transition-colors text-sm"
            >
              {t("nav.service")}
            </a>
          </li>
          <li>
            <a
              href="#certifications"
              class="text-theme-muted hover:text-theme-primary transition-colors text-sm"
            >
              {t("nav.certifications")}
            </a>
          </li>
          <li>
            <a
              href="#portfolio"
              class="text-theme-muted hover:text-theme-primary transition-colors text-sm"
            >
              {t("nav.portfolio")}
            </a>
          </li>
        </ul>
      </div>
      <!-- Contacto -->
      <div class="text-center md:text-left">
        <h3 class="font-medium mb-4">{t("footer.contact")}</h3>
        <ul class="space-y-2">
          <li>
            <a
              href="#contact"
              class="text-theme-muted hover:text-theme-primary transition-colors text-sm"
            >
              {t("footer.contactform")}
            </a>
          </li>
          <li>
            <a
              href="https://brayanalmengordev.netlify.app/"
              target="_blank"
              rel="noopener noreferrer"
              class="text-theme-muted hover:text-theme-primary transition-colors text-sm"
            >
              brayanalmengordev.netlify.app
            </a>
          </li>
        </ul>
      </div>
      <!-- Tecnologías -->
      <div class="text-center md:text-left">
        <h3 class="font-medium mb-4">{t("footer.tech")}</h3>
        <ul class="space-y-2">
          <li class="text-theme-muted text-sm">Java & Spring Boot</li>
          <li class="text-theme-muted text-sm">React & Astro</li>
          <li class="text-theme-muted text-sm">MySQL & Oracle</li>
          <li class="text-theme-muted text-sm">REST APIs</li>
          <li class="text-theme-muted text-sm">Git & CI/CD</li>
        </ul>
      </div>
    </div>

    <div
      class="border-t border-gray-800 mt-8 sm:mt-12 pt-4 sm:pt-6 flex flex-col md:flex-row justify-between items-center text-center md:text-left"
    >
      <p class="text-theme-muted text-sm">
        {t("footer.copyright").replace("{year}", String(currentYear))}
      </p>
    </div>
  </div>
</footer>

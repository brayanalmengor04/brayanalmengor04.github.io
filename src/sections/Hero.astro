---
import { ArrowUpRight } from "lucide-astro";
import { Facebook, Instagram, Linkedin, Sun, Moon } from "lucide-astro";
import ThemeToggleButton from "../components/theme/ThemeToggleButton";
import AOSClient from "../components/AOSClient";

let isDark = false;

function toggleMode() {
  isDark = !isDark;
  document.documentElement.classList.toggle("dark", isDark);
}
---

<section class="w-full bg-primary flex flex-col md:flex-row" id="home">
  <!-- Texto y botones -->
  <div
    data-aos="fade-right"
    class="w-full md:w-1/2 flex flex-col justify-center items-start px-10 space-y-6 mt-40 md:mt-30 transition-all duration-300"
  >
    <h1 class="text-4xl md:text-5xl font-extrabold text-white leading-tight">
      I'm <span
        style="color: var(--accent-primary); text-shadow: 0 0 20px var(--accent-glow);"
        >Brayan Almengor</span
      >, <br /> Backend Developer
    </h1>
    <p class="text-base md:text-lg text-gray-300">
      Backend developer specialized in <span
        class="tech-keyword font-bold"
        style="
          background: linear-gradient(135deg, var(--keyword-gradient-start), var(--keyword-gradient-end));
          -webkit-background-clip: text;
          -webkit-text-fill-color: transparent;
          background-clip: text;
          text-shadow: 0 0 30px var(--keyword-glow);
          transition: all 0.3s ease;
        "
        >Java</span
      >
      and <span
        class="tech-keyword font-bold"
        style="
          background: linear-gradient(135deg, var(--keyword-gradient-start), var(--keyword-gradient-end));
          -webkit-background-clip: text;
          -webkit-text-fill-color: transparent;
          background-clip: text;
          text-shadow: 0 0 30px var(--keyword-glow);
          transition: all 0.3s ease;
        "
        >Spring Boot</span
      >. Passionate about building scalable, efficient, and high-performance
      systems, optimizing databases, and designing robust APIs that drive
      seamless user experiences.
    </p>
    <div
      class="flex flex-col sm:flex-row justify-center sm:justify-start space-y-4 sm:space-y-0 sm:space-x-4 w-full"
    >
      <a
        href="#resume"
        class="group w-full sm:w-auto px-6 py-3 font-semibold rounded-lg shadow-lg transition-all duration-300 text-center hover:scale-105"
        style="background: var(--bg-secondary); color: var(--text-primary); border: 2px solid var(--border-primary);"
      >
        About Me
      </a>
      <a
        href="/file/Brayan_Almengor_Desarrollador_Backend.pdf"
        target="_blank"
        class="w-full sm:w-auto px-6 py-3 bg-theme-magenta-blue font-semibold rounded-lg transition-all duration-300 text-center text-white hover:scale-105 hover:shadow-xl"
      >
        Download CV
      </a>
    </div>
  </div>
  <div
    data-aos="zoom-in"
    class="card_wrapper w-full md:w-3/4 lg:w-1/2 flex justify-center items-center p-5"
  >
    <div>
      <!-- Cambiar el bg-theme-magenta-blue de forma dinamica al cambiar el modo light   -->
      <div class="card_box bg-theme-magenta-blue">
        <div class="card_img_box">
          <img
            src="/image/avatar.png"
            alt="Brayan Almengor"
            class="transition-all duration-500 ease-in-out"
          />
          <div class="card_icon-primary bg-primary">
            <a
              href="https://www.linkedin.com/in/brayan-antonio/"
              target="_blank"
            >
              <ArrowUpRight class="w-15 h-auto" />
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Mobile Social Section - Below Card -->
  <div
    data-aos="fade-up"
    class="md:hidden w-full flex flex-col items-center space-y-4 mt-6 pb-6"
  >
    <!-- Theme Toggle Button for Mobile - Compact -->
    <div class="flex flex-col items-center space-y-2">
      <ThemeToggleButton client:only="react" />
      <p class="text-xs text-theme-secondary tracking-wide">Switch Theme</p>
    </div>

    <!-- Divider Line -->
    <div class="flex items-center space-x-2">
      <div class="w-8 h-px" style="background: var(--accent-glow);"></div>
      <div
        class="w-2 h-2 rounded-full"
        style="background: var(--accent-primary); box-shadow: var(--shadow-glow);"
      >
      </div>
      <div class="w-8 h-px" style="background: var(--accent-glow);"></div>
    </div>

    <!-- Social Buttons Row -->
    <div class="flex items-center justify-center space-x-4">
      <a
        href="#"
        class="p-3 rounded-full transition-all duration-300 transform hover:scale-110 active:scale-95 hover:shadow-lg"
        style="background: var(--icon-bg); box-shadow: var(--shadow-glow);"
      >
        <Facebook
          class="w-6 h-6 transition-colors duration-300"
          style="color: var(--icon-color);"
        />
      </a>

      <a
        href="https://www.instagram.com/aabj_cx"
        class="p-3 rounded-full transition-all duration-300 transform hover:scale-110 active:scale-95 hover:shadow-lg"
        style="background: var(--icon-bg); box-shadow: var(--shadow-glow);"
      >
        <Instagram
          class="w-6 h-6 transition-colors duration-300"
          style="color: var(--icon-color);"
        />
      </a>

      <a
        href="https://www.linkedin.com/in/brayan-antonio/"
        target="_blank"
        class="p-3 rounded-full transition-all duration-300 transform hover:scale-110 active:scale-95 hover:shadow-lg"
        style="background: var(--icon-bg); box-shadow: var(--shadow-glow);"
      >
        <Linkedin
          class="w-6 h-6 transition-colors duration-300"
          style="color: var(--icon-color);"
        />
      </a>
    </div>

    <!-- Follow Text -->
    <p class="text-sm text-theme-secondary font-medium tracking-wide">
      Follow me on Social
    </p>
  </div>

  <!-- Iconos de redes sociales - Desktop Only -->
  <div
    data-aos="fade-up"
    class="hidden md:flex w-20 flex-col justify-center items-center space-y-4 text-white"
  >
    <!-- Componente modo oscuro -->
    <ThemeToggleButton client:only="react" />
    <p class="text-sm rotate-90 text-theme-secondary">Follow me Social:</p>
    <div class="w-px h-12 bg-theme-muted"></div>

    <a
      href="#"
      class="p-2 rounded-full transition-all duration-300 transform hover:scale-125 hover:rotate-6 hover:shadow-lg"
      style="background: var(--icon-bg);"
    >
      <Facebook
        class="w-5 h-5 transition-colors duration-300"
        style="color: var(--icon-color);"
      />
    </a>

    <a
      href="https://www.instagram.com/aabj_cx"
      class="p-2 rounded-full transition-all duration-300 transform hover:scale-125 hover:rotate-6 hover:shadow-lg"
      style="background: var(--icon-bg);"
    >
      <Instagram
        class="w-5 h-5 transition-colors duration-300"
        style="color: var(--icon-color);"
      />
    </a>

    <a
      href="https://www.linkedin.com/in/brayan-antonio/"
      target="_blank"
      class="p-2 rounded-full transition-all duration-300 transform hover:scale-125 hover:rotate-6 hover:shadow-lg"
      style="background: var(--icon-bg);"
    >
      <Linkedin
        class="w-5 h-5 transition-colors duration-300"
        style="color: var(--icon-color);"
      />
    </a>
  </div>
</section>

<AOSClient client:load />

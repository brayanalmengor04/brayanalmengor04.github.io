---
import { ArrowUpRight } from "lucide-astro";
import { Facebook, Instagram, Linkedin } from "lucide-astro";
import ThemeToggleButton from "../components/theme/ThemeToggleButton";
import LanguagePicker from "../components/LanguagePicker.astro";
import AOSClient from "../components/AOSClient";
import { useTranslations } from "../i18n/utils";

const { lang = "es" } = Astro.props;
const t = useTranslations(lang);

// Estilos de texto (Gradientes para Java y Spring Boot)
const javaSpan = `<span class="tech-keyword font-bold" style="background: linear-gradient(135deg, var(--keyword-gradient-start), var(--keyword-gradient-end)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; text-shadow: 0 0 30px var(--keyword-glow); transition: all 0.3s ease;">Java</span>`;
const springBootSpan = `<span class="tech-keyword font-bold" style="background: linear-gradient(135deg, var(--keyword-gradient-start), var(--keyword-gradient-end)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; text-shadow: 0 0 30px var(--keyword-glow); transition: all 0.3s ease;">Spring Boot</span>`;

const descriptionHtml = t("hero.description")
  .replace("{java}", javaSpan)
  .replace("{springboot}", springBootSpan);
---

<section
  class="w-full min-h-screen bg-primary flex flex-col md:flex-row relative overflow-hidden"
  id="home"
>
  <div
    class="absolute top-[-10%] right-[-5%] w-[600px] h-[600px] bg-theme-magenta-blue opacity-10 blur-[100px] rounded-full pointer-events-none z-0"
  >
  </div>

  <div
    data-aos="fade-right"
    class="w-full md:w-1/2 flex flex-col justify-center items-start px-8 md:px-16 space-y-8 mt-24 md:mt-0 z-10"
  >
    <div class="space-y-2">
      <h1 class="text-4xl md:text-6xl font-extrabold text-white leading-tight">
        {t("hero.greeting")}
        <br />
        <span
          style="color: var(--accent-primary); text-shadow: 0 0 20px var(--accent-glow);"
        >
          Brayan Almengor
        </span>, <br />
        <span class="text-2xl md:text-4xl text-gray-400 font-light mt-2 block">
          {t("hero.role")}
        </span>
      </h1>
    </div>

    <p
      class="text-base md:text-lg text-gray-300 max-w-lg leading-relaxed"
      set:html={descriptionHtml}
    />

    <div class="flex flex-col sm:flex-row gap-4 w-full sm:w-auto pt-2">
      <a
        href="#experience-services"
        class="group w-full sm:w-auto px-8 py-3.5 font-semibold rounded-lg shadow-lg transition-all duration-300 text-center hover:scale-105 border border-[var(--border-primary)] bg-[var(--bg-secondary)] text-[var(--text-primary)]"
      >
        {t("hero.button.about")}
      </a>
      <a
        href="/file/Brayan_Almengor_Desarrollador_Backend.pdf"
        target="_blank"
        class="w-full sm:w-auto px-8 py-3.5 bg-theme-magenta-blue font-semibold rounded-lg transition-all duration-300 text-center text-white hover:scale-105 hover:shadow-xl flex items-center justify-center gap-2"
      >
        {t("hero.button.cv")}
        <ArrowUpRight
          class="w-4 h-4 transition-transform group-hover:translate-x-1 group-hover:-translate-y-1"
        />
      </a>
    </div>
  </div>

  <div
    data-aos="zoom-in"
    data-aos-duration="1000"
    class="w-full md:w-1/2 flex justify-center items-center p-5 z-10 relative mt-8 md:mt-0"
  >
    <div class="card_wrapper">
      <div>
        <div class="card_box bg-theme-magenta-blue">
          <div class="card_img_box">
            <img
              src="/image/avatar.png"
              alt="Brayan Almengor"
              class="transition-all duration-500 ease-in-out"
            />
            <div class="card_icon-primary bg-primary">
              <a
                href="https://www.linkedin.com/in/brayan-antonio/"
                target="_blank"
                class="hover:text-theme-magenta-blue transition-colors"
              >
                <ArrowUpRight class="w-15 h-auto" />
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div
    data-aos="fade-left"
    data-aos-delay="200"
    class="hidden md:flex fixed right-8 top-1/2 -translate-y-1/2 flex-col items-center z-50"
  >
    <div
      class="flex flex-col items-center gap-6 py-6 px-3 rounded-full bg-white/5 backdrop-blur-xl border border-white/10 shadow-2xl transition-all duration-300 hover:border-theme-magenta-blue/30"
    >
      <div class="flex flex-col gap-4 items-center">
        <ThemeToggleButton client:only="react" />
        <LanguagePicker lang={lang} />
      </div>
      <div class="w-6 h-px bg-white/20"></div>
      <div class="flex flex-col gap-5 items-center">
        <a
          href="#"
          class="text-gray-400 hover:text-blue-500 hover:scale-110 transition-all duration-300 p-1"
          ><Facebook class="w-5 h-5" /></a
        >
        <a
          href="https://www.instagram.com/aabj_cx"
          class="text-gray-400 hover:text-pink-500 hover:scale-110 transition-all duration-300 p-1"
          ><Instagram class="w-5 h-5" /></a
        >
        <a
          href="https://www.linkedin.com/in/brayan-antonio/"
          target="_blank"
          class="text-gray-400 hover:text-blue-400 hover:scale-110 transition-all duration-300 p-1"
          ><Linkedin class="w-5 h-5" /></a
        >
      </div>
    </div>
  </div>

  <div
    data-aos="fade-up"
    class="md:hidden w-full flex justify-center pb-12 pt-6 z-20 relative"
  >
    <div
      class="flex flex-col items-center gap-5 p-6 rounded-3xl bg-white/5 backdrop-blur-lg border border-white/10 shadow-xl w-[90%] max-w-sm"
    >
      <div class="flex items-center justify-between w-full px-8">
        <a
          href="#"
          class="text-gray-400 hover:text-blue-500 transition-all transform hover:scale-110"
          ><Facebook class="w-6 h-6" /></a
        >
        <a
          href="https://www.instagram.com/aabj_cx"
          class="text-gray-400 hover:text-pink-500 transition-all transform hover:scale-110"
          ><Instagram class="w-6 h-6" /></a
        >
        <a
          href="https://www.linkedin.com/in/brayan-antonio/"
          target="_blank"
          class="text-gray-400 hover:text-blue-400 transition-all transform hover:scale-110"
          ><Linkedin class="w-6 h-6" /></a
        >
      </div>

      <div class="w-full h-px bg-white/10"></div>

      <div class="flex items-center gap-6">
        <ThemeToggleButton client:only="react" />
        <div class="w-px h-5 bg-white/20"></div>
        <LanguagePicker lang={lang} />
      </div>
    </div>
  </div>
</section>

<AOSClient client:load />

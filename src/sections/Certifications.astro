---
import AOSClient from "../components/AOSClient";
import { useTranslations } from "../i18n/utils";
import { FileCheck } from "lucide-astro";
import CertificationsCarousel from "../components/CertificationsCarousel";

const { lang = "es" } = Astro.props;
const t = useTranslations(lang);
---

<section class="py-20 relative overflow-hidden" id="certifications">
    <AOSClient client:load />

    {/* Background Elements */}
    <div class="absolute inset-0 pointer-events-none">
        <div
            class="absolute top-[20%] right-[10%] w-[500px] h-[500px] bg-primary/5 rounded-full blur-[120px] animate-pulse"
        >
        </div>
        <div
            class="absolute bottom-[10%] left-[10%] w-[400px] h-[400px] bg-blue-500/5 rounded-full blur-[100px] animate-pulse delay-1000"
        >
        </div>
    </div>

    <div class="container mx-auto px-6 relative z-10">
        <div class="text-center mb-12 space-y-4" data-aos="fade-up">
            <div
                class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-secondary/30 backdrop-blur-sm border border-border/40 text-sm font-mono text-muted-foreground hover:bg-secondary/50 transition-colors duration-300"
            >
                <FileCheck class="w-4 h-4" />
                <span class="tracking-wide">{t("certifications.subtitle")}</span
                >
            </div>

            <h2
                class="text-4xl md:text-6xl font-black tracking-tight text-theme-primary"
            >
                {t("certifications.title")}
            </h2>
        </div>

        {/* Carousel Component */}
        <div data-aos="fade-up" data-aos-delay="200">
            <CertificationsCarousel client:visible lang={lang} />
        </div>
    </div>
</section>

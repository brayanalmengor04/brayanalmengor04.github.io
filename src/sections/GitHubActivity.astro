---
import { Github, BarChart3, Terminal as TerminalIcon, GitCommit, Star, GitFork, ExternalLink } from "lucide-astro";
import { useTranslations } from "../i18n/utils";

const { lang = "es" } = Astro.props;
const t = useTranslations(lang);

const GITHUB_TOKEN = import.meta.env.GITHUB_TOKEN;
const GITHUB_USERNAME = import.meta.env.GITHUB_USERNAME || "brayanalmengor04";

interface GitHubRepo {
  stargazerCount: number;
  languages: {
    edges: Array<{
      size: number;
      node: {
        name: string;
        color: string;
      };
    }>;
  };
}

interface GitHubCommit {
  oid: string;
  message: string;
  committedDate: string;
  repository: {
    name: string;
  };
}

interface GitHubData {
  repositories: {
    totalCount: number;
    nodes: GitHubRepo[];
  };
  contributionsCollection: {
    totalCommitContributions: number;
    contributionCalendar: {
      totalContributions: number;
    };
  };
  recentCommits: {
    nodes: Array<{
      name: string;
      defaultBranchRef: {
        target: {
          history: {
            nodes: GitHubCommit[];
          };
        };
      } | null;
    }>;
  };
}

async function fetchGitHubData(): Promise<GitHubData | null> {
  const query = `
    query($username: String!) {
      user(login: $username) {
        repositories(first: 100, ownerAffiliations: OWNER) {
          totalCount
          nodes {
            stargazerCount
            forkCount
            languages(first: 10, orderBy: {field: SIZE, direction: DESC}) {
              edges {
                size
                node {
                  name
                  color
                }
              }
            }
          }
        }
        contributionsCollection {
          totalCommitContributions
          contributionCalendar {
            totalContributions
          }
        }
        recentCommits: repositories(first: 5, ownerAffiliations: OWNER, orderBy: {field: PUSHED_AT, direction: DESC}) {
          nodes {
            name
            defaultBranchRef {
              target {
                ... on Commit {
                  history(first: 3) {
                    nodes {
                      oid
                      message
                      committedDate
                      repository {
                        name
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  `;

  try {
    const response = await fetch("https://api.github.com/graphql", {
      method: "POST",
      headers: {
        Authorization: `Bearer ${GITHUB_TOKEN}`,
        "Content-Type": "application/json",
      },
      body: JSON.stringify({ query, variables: { username: GITHUB_USERNAME } }),
    });

    const result = await response.json();
    return result.data.user;
  } catch (error) {
    console.error("Error fetching GitHub data:", error);
    return null;
  }
}

const githubData = await fetchGitHubData();

// Process stats
const totalRepos = githubData?.repositories.totalCount || 0;
const totalStars = githubData?.repositories.nodes.reduce((acc, node) => acc + node.stargazerCount, 0) || 0;
const totalCommits = githubData?.contributionsCollection.contributionCalendar.totalContributions || 0;

// Process languages
const languagesMap: Record<string, { name: string; color: string; size: number }> = {};
githubData?.repositories.nodes.forEach(repo => {
  repo.languages.edges.forEach(edge => {
    const { name, color } = edge.node;
    if (!languagesMap[name]) {
      languagesMap[name] = { name, color, size: 0 };
    }
    languagesMap[name].size += edge.size;
  });
});

const sortedLanguages = Object.values(languagesMap)
  .sort((a, b) => b.size - a.size)
  .slice(0, 5);

const totalSize = sortedLanguages.reduce((acc: number, lang) => acc + lang.size, 0);

// Process recent activity
const recentCommits = githubData?.recentCommits.nodes
  .flatMap(repo => repo.defaultBranchRef?.target.history.nodes || [])
  .sort((a, b) => new Date(b.committedDate).getTime() - new Date(a.committedDate).getTime())
  .slice(0, 4);

const timeAgo = (date: string) => {
  const seconds = Math.floor((new Date().getTime() - new Date(date).getTime()) / 1000);
  let interval = seconds / 31536000;
  if (interval > 1) return t("time.yearsAgo").replace("{time}", Math.floor(interval).toString());
  interval = seconds / 2592000;
  if (interval > 1) return t("time.monthsAgo").replace("{time}", Math.floor(interval).toString());
  interval = seconds / 86400;
  if (interval > 1) return t("time.daysAgo").replace("{time}", Math.floor(interval).toString());
  interval = seconds / 3600;
  if (interval > 1) return t("time.hoursAgo").replace("{time}", Math.floor(interval).toString());
  interval = seconds / 60;
  if (interval > 1) return t("time.minutesAgo").replace("{time}", Math.floor(interval).toString());
  if (seconds < 30) return t("time.justNow");
  return t("time.secondsAgo").replace("{time}", Math.floor(seconds).toString());
};
---

<section id="github-activity" class="bg-primary py-24 px-6 md:px-12 relative overflow-hidden">
  {/* Background Decoration */}
  <div class="absolute top-0 right-0 w-96 h-96 bg-accent/5 rounded-full blur-[120px] pointer-events-none"></div>
  <div class="absolute bottom-0 left-0 w-96 h-96 bg-purple-500/5 rounded-full blur-[120px] pointer-events-none"></div>

  <div class="max-w-6xl mx-auto relative z-10">
    {/* Section Header */}
    <div class="flex items-center gap-4 mb-12" data-aos="fade-right">
      <div class="p-3 bg-theme-magenta-blue/20 rounded-xl border border-theme-magenta-blue/30">
        <Github class="w-8 h-8 text-accent" />
      </div>
      <h2 class="text-4xl md:text-5xl font-black text-theme-primary tracking-tight">
        {t("github.title")}
      </h2>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
      {/* Card 1: Contribution Stats */}
      <div 
        class="lg:col-span-2 bg-card border border-theme rounded-3xl p-8 relative overflow-hidden group"
        data-aos="fade-up"
      >
        <div class="flex justify-between items-start mb-12">
          <div class="flex items-center gap-2 text-theme-secondary font-mono text-sm">
            <BarChart3 class="w-4 h-4 text-neon-green" />
            <span>{t("github.contributionStats")}</span>
          </div>
          <a href={`https://github.com/${GITHUB_USERNAME}`} target="_blank" class="text-theme-muted hover:text-accent transition-colors">
            <ExternalLink class="w-5 h-5" />
          </a>
        </div>

        <div class="flex flex-col mb-8">
          <div class="flex items-baseline gap-2">
            <span class="text-7xl md:text-8xl font-black text-theme-primary">{totalCommits}</span>
            <span class="text-4xl font-bold text-neon-green">+</span>
          </div>
          <span class="text-theme-secondary text-lg font-medium">{t("github.totalContributions")}</span>
        </div>

        <div class="flex gap-4">
          <div class="flex items-center gap-2 px-4 py-2 bg-primary/50 rounded-full border border-theme text-sm text-theme-secondary">
            <GitCommit class="w-4 h-4 text-accent" />
            <span>{totalRepos} {t("github.repos")}</span>
          </div>
          <div class="flex items-center gap-2 px-4 py-2 bg-primary/50 rounded-full border border-theme text-sm text-theme-secondary">
            <Star class="w-4 h-4 text-yellow-400" />
            <span>{totalStars} {t("github.stars")}</span>
          </div>
        </div>
      </div>

      {/* Card 2: Top Languages */}
      <div 
        class="bg-card border border-theme rounded-3xl p-8"
        data-aos="fade-up"
        data-aos-delay="100"
      >
        <div class="flex items-center gap-2 text-theme-secondary font-mono text-sm mb-8">
          <span class="text-accent font-bold">&lt;/&gt;</span>
          <span>{t("github.topLanguages")}</span>
        </div>

        {/* Multi-segment Progress Bar */}
        <div class="flex w-full h-3 rounded-full overflow-hidden bg-primary mb-10">
          {sortedLanguages.map((lang) => (
            <div 
              style={{ width: `${(lang.size / totalSize) * 100}%`, backgroundColor: lang.color || '#583ebc' }}
              class="h-full transition-all duration-1000"
              title={`${lang.name}: ${Math.round((lang.size / totalSize) * 100)}%`}
            ></div>
          ))}
        </div>

        <ul class="space-y-6">
          {sortedLanguages.map((lang) => (
            <li class="flex items-center justify-between group">
              <div class="flex items-center gap-3">
                <div class="w-3 h-3 rounded-full" style={{ backgroundColor: lang.color || '#583ebc' }}></div>
                <span class="text-theme-primary font-medium group-hover:text-accent transition-colors">{lang.name}</span>
              </div>
              <span class="text-theme-secondary font-mono text-sm">{Math.round((lang.size / totalSize) * 100)}%</span>
            </li>
          ))}
        </ul>
      </div>

      {/* Card 3: Activity Feed (Terminal) */}
      <div 
        class="lg:col-span-3 bg-card border border-theme rounded-2xl overflow-hidden"
        data-aos="fade-up"
      >
        {/* Terminal Header */}
        <div class="bg-primary/50 border-b border-theme px-4 py-3 flex items-center justify-between">
          <div class="flex gap-2">
            <div class="w-3 h-3 rounded-full bg-[#ff5f56]"></div>
            <div class="w-3 h-3 rounded-full bg-[#ffbd2e]"></div>
            <div class="w-3 h-3 rounded-full bg-[#27c93f]"></div>
          </div>
          <div class="flex items-center gap-2 text-theme-secondary font-mono text-xs">
            <TerminalIcon class="w-3 h-3" />
            <span>activity-feed.sh</span>
          </div>
          <div class="w-12"></div>
        </div>

        {/* Terminal Body */}
        <div class="p-6 font-mono text-sm md:text-base overflow-x-auto custom-scrollbar">
          <div class="min-w-max">
            <div class="flex gap-2 mb-6">
              <span class="text-neon-green">$</span>
              <span class="text-theme-primary">git log --oneline --all</span>
            </div>

            <div class="space-y-4">
              {recentCommits?.map((commit) => (
                <div class="flex items-center justify-between gap-8 group hover:bg-theme-secondary/5 p-2 rounded-lg -ml-2 transition-colors">
                  <div class="flex items-center gap-3">
                    <span class="text-yellow-500 shrink-0">{commit.oid.substring(0, 7)}</span>
                    <span class="text-accent font-bold shrink-0">[{commit.repository.name}]</span>
                    <span class="text-theme-secondary group-hover:text-theme-primary transition-colors whitespace-nowrap">{commit.message}</span>
                  </div>
                  <span 
                    class="time-ago text-theme-muted text-xs shrink-0 whitespace-nowrap" 
                    data-timestamp={commit.committedDate}
                  >
                    {timeAgo(commit.committedDate)}
                  </span>
                </div>
              ))}
            </div>

            <div class="flex items-center gap-2 mt-6">
              <span class="text-neon-green">$</span>
              <div class="w-2 h-5 bg-theme-secondary animate-pulse"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script define:vars={{ 
  translations: {
    yearsAgo: t("time.yearsAgo"),
    monthsAgo: t("time.monthsAgo"),
    daysAgo: t("time.daysAgo"),
    hoursAgo: t("time.hoursAgo"),
    minutesAgo: t("time.minutesAgo"),
    secondsAgo: t("time.secondsAgo"),
    justNow: t("time.justNow"),
  } 
}}>
  function updateTimeAgo() {
    const elements = document.querySelectorAll('.time-ago');
    elements.forEach(el => {
      const timestamp = el.getAttribute('data-timestamp');
      if (!timestamp) return;

      const date = new Date(timestamp);
      const seconds = Math.floor((new Date().getTime() - date.getTime()) / 1000);
      
      let text = "";
      let interval = seconds / 31536000;
      
      if (interval > 1) {
        text = translations.yearsAgo.replace("{time}", Math.floor(interval).toString());
      } else {
        interval = seconds / 2592000;
        if (interval > 1) {
          text = translations.monthsAgo.replace("{time}", Math.floor(interval).toString());
        } else {
          interval = seconds / 86400;
          if (interval > 1) {
            text = translations.daysAgo.replace("{time}", Math.floor(interval).toString());
          } else {
            interval = seconds / 3600;
            if (interval > 1) {
              text = translations.hoursAgo.replace("{time}", Math.floor(interval).toString());
            } else {
              interval = seconds / 60;
              if (interval > 1) {
                text = translations.minutesAgo.replace("{time}", Math.floor(interval).toString());
              } else if (seconds < 30) {
                text = translations.justNow;
              } else {
                text = translations.secondsAgo.replace("{time}", Math.floor(seconds).toString());
              }
            }
          }
        }
      }
      
      if (el.textContent !== text) {
        el.textContent = text;
      }
    });
  }

  // Update every 10 seconds to keep "seconds ago" relatively accurate
  // but not too frequent to impact performance
  setInterval(updateTimeAgo, 10000);
  
  // Also run immediately on load (though Astro already rendered it, 
  // it might have been some time since the build/SSR)
  updateTimeAgo();
</script>

<style>
  .animate-pulse {
    animation: pulse 1s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  }

  @keyframes pulse {
    0%, 100% {
      opacity: 1;
    }
    50% {
      opacity: 0.5;
    }
  }

  .line-clamp-1 {
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Custom subtle scrollbar for the terminal feed */
  .custom-scrollbar::-webkit-scrollbar {
    height: 6px;
  }
  .custom-scrollbar::-webkit-scrollbar-track {
    background: transparent;
  }
  .custom-scrollbar::-webkit-scrollbar-thumb {
    background: var(--accent-primary, #583ebc);
    border-radius: 4px;
    opacity: 0.5;
  }
  .custom-scrollbar::-webkit-scrollbar-thumb:hover {
    background: var(--accent-secondary, #9333ea);
  }
</style>
